# Web Client Environment Configuration
# Copy this file to .env.local and fill in your actual values:
#   cp .env.example .env.local

# Firebase Web API key (Project settings → General → Your apps → Web app → apiKey)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key_here

# Backend API URL (FastAPI server)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Backend WebSocket URL (voice streaming endpoint)
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000/api/voice
