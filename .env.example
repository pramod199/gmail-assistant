# Gmail Assistant Environment Configuration
# Copy this file to .env and fill in your actual values

# ===== Environment =====
ENVIRONMENT=development

# ===== Gemini API =====
GEMINI_API_KEY=your_gemini_api_key_here

# ===== API Configuration =====
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000

# ===== Firebase Configuration =====
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_WEB_API_KEY=your_firebase_web_api_key_here

# ===== Redis Configuration =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_DB_SESSIONS=0
REDIS_DB_DRAFTS=0
REDIS_DB_CREDENTIALS=0

# ===== OAuth Configuration =====
OAUTH_REDIRECT_URI_PROD=https://yourdomain.com/api/auth/gmail/callback
OAUTH_STATE_SECRET=your_secret_key_for_oauth_state_change_this_in_production

# ===== Gmail Configuration =====
GMAIL_CREDENTIALS_FILE=./credentials.json

# ===== Voice Session Configuration =====
VOICE_SESSION_TTL=86400
MAX_CONCURRENT_SESSIONS_PER_USER=3

# ===== WebSocket Configuration =====
WS_CLOSE_TIMEOUT=5
WS_PING_INTERVAL=30
WS_PING_TIMEOUT=10
